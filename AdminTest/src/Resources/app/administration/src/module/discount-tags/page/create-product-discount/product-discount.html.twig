<sw-page>
        <template #search-bar>
                <sw-search-bar>
                </sw-search-bar>
        </template>
        <template #smart-bar-header>
                <h2 v-if="tagId">Discount für {{ tagName }}</h2>
                <h2 v-else> Discount für alle Kunden</h2>
        </template>
        <template #smart-bar-actions>
                <sw-button
                        variant="primary"
                        @click="onSave">
                        Save
                </sw-button>
        </template>
        <template #content>


                        <mt-card
                                large="True"
                                :title="$tc('adminTest.create.title')"

                        >
                                <sw-entity-single-select
                                        v-model:value="discount.productId"
                                        entity="product"
                                        placeholder="Enter Article"
                                        show-clearable-button
                                        label="Artikel"
                                />

                                <mt-switch label="Switchfield"
                                           v-model="fixedPrice"

                                />

                                <p>modelValue: {{ fixedPrice }}</p>


                                <mt-number-field
                                        v-if="!fixedPrice"
                                        :label="$tc('adminTest.create.discountLabel')"
                                        v-model="discount.discount"
                                        min="0"
                                        max="2"
                                        required="false"
                                />
                                <mt-text-field
                                        v-if="!fixedPrice"
                                        :label="$tc('adminTest.create.basePriceLabel')"
                                        v-model="discount.priceReference"
                                />
                                <mt-number-field
                                        v-if="fixedPrice"
                                        label="FixPreis"
                                        v-model="discount.fixedPrice"
                                        min="0"
                                        required="false"
                                />


                                <mt-textarea
                                        label="Kommentar"
                                        v-model="discount.comment"
                                />


                        </mt-card>
            <sw-card title="Excel Upload">
                <sw-file-input
                        accept=".xlsx,.csv"
                        v-model:value="excelFile"
                        @update:value="onUpload" />

                <div v-if="fileUploaded === true">
                    <p>File Uploaded</p>
                    <BButton @click="this.uploadAllDiscounts">Upload Discounts</BButton>

                    <BTable :items="uploadRows"></BTable>

                </div>
            </sw-card>




        </template>


</sw-page>