{% sw_extends "@Storefront/storefront/page/account/order-history/order-item.html.twig" %}
{% set trackingCodes = order.primaryOrderDelivery.trackingCodes %}
{% block page_account_order_item_status_badge %}

    {% if order.primaryOrderDelivery.StateMachineState.technicalName == "shipped" %}

    <span class="badge badge-lg order-item-status-badge order-item-status-badge-completed">
        <span class="visually-hidden">{{ 'account.orderStatus'|trans|sw_sanitize }}</span>
        Shipped</span>

    {% else %}
    <span class="badge badge-lg order-item-status-badge order-item-status-badge-{{ orderState }}">
        <span class="visually-hidden">{{ 'account.orderStatus'|trans|sw_sanitize }}</span>
        {{ order.stateMachineState.translated.name }}</span>
    {% endif %}

{% endblock %}
{% block page_account_order_item_order_number_col %}
    {{ parent() }}
    {% if order.customFields.custom_order_reference %}
    <div class="col-12 order-table-header-order-number">
    {% block page_account_order_item_order_reference_number %}
        <strong class="order-table-header-label">Referenz: </strong>
        <span class="order-table-body-value">{{ order.customFields.custom_order_reference }}</span>

    {% endblock %}
    {% endif %}
    {% if order.primaryOrderDelivery.StateMachineState.technicalName == "shipped" and trackingCodes %}
    <div class="col-12 order-table-header-order-number">
    {% block page_account_order_item_order_tracking %}
        <div>
        <strong class="order-table-header-label">Tracking: </strong>
        </div>
        {% for trackingCode in trackingCodes %}
        <span class="order-table-body-value">
            <a href="{{ order.primaryOrderDelivery.shippingMethod.trackingUrl }}{{ trackingCode }}"
               target="_blank" rel="noopener noreferrer">
                {{ order.primaryOrderDelivery.shippingMethod.trackingUrl }}{{ trackingCode }}
            </a><br>
        </span>
        {% endfor %}
    {% endblock %}
    {% endif %}
        {% block page_account_order_item_order_table_header_cell_payment_status %}
        {% endblock %}
        {% block page_account_order_item_order_table_body_cell_payment_status %}
        {% endblock %}

{% endblock %}